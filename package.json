    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
