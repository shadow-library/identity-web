{
  "name": "identity-web",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "bun main.ts",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit",
