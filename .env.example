# Base URL of the identity server. TanStack Start server functions call it directly (server-side),
# and the dev/preview proxy forwards the browser-facing /oauth2 and /saml2 redirect endpoints to it.
SERVER_URL=http://localhost:9091

# OpenAPI spec used by `bun run generate:api-types` to regenerate src/lib/apis/api-types.gen.ts.
OPENAPI_SPEC_URL=http://localhost:9091/dev/api-docs/openapi.json
